# MASTER multitail config
# /opt/davit/lib/multitail/davit-admin-log.config
# Version: 0.1.0
# REVIEW: https://github.com/halturin/multitail/blob/master/multitail.conf
#         file:///home/github.com/folkertvanheusden/multitail/manual.html
# #colors can be red, green, yellow, blue, magenta, cyan, or white, optionally combined with background colors and attributes like bold or inverse. 
# ANSI 256 color scheme (0-256).  https://www.ditig.com/256-colors-cheat-sheet


## TODO 
## col2 (user)
#cs_re_s:198:^[^|]+ \| ([^|]+) \| [^|]+ \| [^|]+ \| [^|]+ \| [^|]+:[^|]+ \| \[[^|]+:[^|]+\] \| \[[^|]+\] \| .+

## Define a reusable mental pattern:
# COL = [^|]+
# SEP = \|
## Then each column becomes predictable:
# ^COL \| (COL) \| COL \| COL ..

# 🚀 Big upgrade idea (optional but powerful)
# Since you’re already modifying logs, consider this format:
# 2026-04-19 11:56:12.887 | david | WARN | ADMIN | - | generic | - | MODE=dev | pid=9707 | script=test.sh | message...


# pid=([^|]+)
# MODE=([^|]+)


defaultcscheme:davit-base

# =========================
# BASE
# =========================
colorscheme:davit-base
# shared rules (e.g. timestamp, pid, etc.)

# === Log levels (whole line) ===
cs_re:red,,bold:ERROR|ERR|FAIL|FAILED|FATAL|EXCEPTION|CRITICAL
cs_re:yellow,,bold:WARN|WARNING
cs_re:green,,bold:INFO|SUCCESS|OK|DONE|COMPLETED
cs_re:magenta,,bold:DEBUG|TRACE
cs_re:cyan:\\[(INFO|DEBUG)\\\\]


# =========================
# ADMIN LOGS
# =========================
colorscheme:davit-admin
titlebar:DAVIT-ADMIN-LOGS
bright:1
abbreviate_filesize:on
shell:/usr/bin/bash

# === Log levels (whole line) ===
cs_re:red,,bold:ERROR|ERR|FAIL|FAILED|FATAL|EXCEPTION|CRITICAL
cs_re:yellow,,bold:WARN|WARNING
cs_re:green,,bold:INFO|SUCCESS|OK|DONE|COMPLETED
cs_re:magenta,,bold:DEBUG|TRACE
# cs_re:201:\\[(INFO|DEBUG)\\\\]
cs_re:201:\[(INFO|DEBUG)\]

# === Status / keyword coloring (expand with your statuses.json values) ===
cs_re:green:success|completed|ready|active|started|ok
cs_re:red:error|failed|exception|timeout|stopped|critical
cs_re:yellow:warning|pending|retry|partial|slow
cs_re:cyan:info|notice|processing|running

 
# === MODE / keyword coloring ===
cs_re:yellow:stage
cs_re:green:prod
cs_re:213,,blink:dev

# === SPECIAL CHARS ===
cs_re:magenta,,bold:\]|\[

# col1 (timestamp)
cs_re:195:^[0-9 :\.\-][^|]+

# col2 (user)
#cs_re_s:198:^.+ \| (.+) \| .+ \| .+ \| .+ \| .+:.+ \| \[.*:.+\] \| \[.+\] \| .+

cs_re_s:198:^[^|]+ \| ([^|]+) \| [^|]+ \| [^|]+ \| [^|]+ \| [^|]+:[^|]+ \| \[[^|]+:[^|]+\] \| \[[^|]+\] \| .+

# col3 (level)
cs_re_s:cyan:^.+ \| .+ \| (.+) \| .+ \| .+ \| .+:.+ \| \[.*:.+\] \| \[.+\] \| .+
# col4 (category)
cs_re_s:magenta:^.+ \| .+ \| .+ \| (.+) \| .+ \| .+:.+ \| \[.*:.+\] \| \[.+\] \| .+
# col5 (category)
cs_re_s:red:^.+ \| .+ \| .+ \| .+ \| (.+) \| .+:.+ \| \[.*:.+\] \| \[.+\] \| .+
# col6 (MODE)
cs_re_s:blue:^.+ \| .+ \| .+ \| .+ \| .+ \| (.+):.+ \| \[.*:.+\] \| \[.+\] \| .+
# col7 (PID)
cs_re_s:blue:^.+ \| .+ \| .+ \| .+ \| .+ \| .+:.+ \| \[(.*):.+\] \| \[.+\] \| .+
# col8 (file)
cs_re_s:green:^.+ \| .+ \| .+ \| .+ \| .+ \| .+:.+ \| \[.*:.+\] \| \[(.+)\] \| .+
# col9 (message)
cs_re_s:191:^.+ \| .+ \| .+ \| .+ \| .+ \| .+:.+ \| \[.*:.+\] \| \[.+\] \| (.+)


# default colorschemes:
scheme:davit-admin:/opt/davit/logs/*-admin.log
