#!/bin/bash
# ==============================================================================
# Script      : INSTALL
# Description : davit-logger deployment One-line description of what this script does
# Author      : David Mullins
# Created     : 2026-03-01
# Version     : 0.3.4
# ==============================================================================

# ──────────────────────────────────────────────────────────────────────────────
# Source central logger + environment (fail-fast if missing)
# ──────────────────────────────────────────────────────────────────────────────
# shellcheck source=/dev/null

set -euo pipefail

# === DAVIT LOGGER METADATA (strict) ===
export D_CATEGORY="${D_CATEGORY:-PROJECT}"


# For production/generic install scripts you can force:
# export D_PRJ_NAME="davit-logger"
export D_PRJ_VER="$(/opt/davit/bin/get-version.sh ./.env)"

source /opt/davit/bin/davit-logger.sh


source ".env" || {
     echo "There is no \".env\"" >&2
     exit 1
}

export D_MODE="${MODE:-}"          # leave empty for auto-detection

this_SCRIPT_VERSION="$(/opt/davit/bin/get-version.sh "$0")"

# Then use:

# log_info "Deploying davit-logger.sh"
# log_term "Pretty output only on terminal"
# log_todo "Review install manifest" "TODO-20260418-001"
#---------------------------------------------------------------------
install_file() {
    local src version base
    src="$1" 
    dest_dir="$2" 
    perms="${3:-755}"
    version=$(/opt/davit/bin/get-version.sh "$src")
    base=$(basename "$src")

    #  echo "|---SRC---|---DEST---|---PERM---|---VER---|"
    #  echo "| $src | $dest_dir | $perms | $version |"
     mkdir -p "$dest_dir" 
     cp "$src" "$dest_dir/"
     chmod "$perms" "$dest_dir/$base"
    log_info "Installed $base v${version} → $dest_dir"
}
#..------------------------------------------------------------------


main() {
    log_info "=== davit-logger installer v${this_SCRIPT_VERSION} ==="
   # echo "line--63  -${D_PRJ_PATH}"
    # 1. Logger script
    install_file "${D_PRJ_PATH}/scripts/davit-logger.sh" "$_D_BIN" 755
   # echo "line--66"
    # 2. Theme JSON
    mkdir -p "$_D_LIB"
     cp "${D_PRJ_PATH}/lib/configs/davit-logger/loggin-theme.json" "$_D_LIB/"
    log_info "Theme JSON → $_D_LIB/loggin-theme.json"

    # 3. Update .env if present in project root
    
    ENV_FILE="${D_PRJ_PATH}/.env"
    LOGGER="$_D_BIN/davit-logger.sh"
    expresion="s|^LOGGER=.*|LOGGER=${LOGGER}|"
    if grep -q "^LOGGER=" "$ENV_FILE"; then
        # Replace the existing value (found)
        sed -i "${expresion}" "$ENV_FILE"
        log_info "LOGGER value updated to ${LOGGER}."
    else
        # Append the new variable (not found)
        echo "LOGGER=${LOGGER}" >> "$ENV_FILE"
        log_info "LOGGER=${LOGGER} added to file."
    fi

    log_success "Installation complete – you can now source /opt/davit/bin/davit-logger.sh"
}

uninstall() {
     rm -f "${_D_BIN}/davit-logger.sh"
     rm -rf "${_D_LIB}/davit-logger"
    log_info "Uninstalled davit-logger"
}

case "${1:-}" in
    -i|--install) main ;;
    -u|--uninstall) uninstall ;;
    *) echo "Usage: $0 [-i|-u]"; exit 1 ;;
esac